{
  "_comment": "Codex Hooks 配置模板",
  "_path": "~/.codex/hooks.json",
  "_note": "以下路径为 OpenWolf 用户配置。普通用户可删除 PreToolUse/PostToolUse/SessionStart/Stop 中引用 .wolf/ 和 .claude/scripts/ 的钩子。",

  "hooks": {
    "PreToolUse": [
      {
        "_comment": "Bash 命令走 RTK 代理省 token（可选，需安装 rtk）",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "_comment": "OpenWolf 预读钩子（可选）",
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.wolf/hooks/pre-read.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "_comment": "OpenWolf 预写钩子（可选）",
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.wolf/hooks/pre-write.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.wolf/hooks/post-read.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.wolf/hooks/post-write.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "_comment": "OpenWolf 会话初始化（可选）",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/session-start.sh",
            "timeout": 10,
            "statusMessage": "Loading..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/token-max-init.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.wolf/hooks/session-start.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_comment": "OpenWolf 上下文提示（可选）",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/wolf-context-hint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/token-rollup.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.wolf/hooks/stop.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
